# ==========================================
# SERVER ENVIRONMENT VARIABLES (.env)
# ==========================================

# Server Port & Node Environment
PORT=3000
NODE_ENV=production

# Client Application URL for CORS
CLIENT_URL=http://localhost:5173

# Database Connection (Supabase PostgreSQL or local Postgres)
DATABASE_URL=postgresql://postgres:password@db.xmmrwzzmoiemhkhvquth.supabase.co:5432/postgres?pgbooster=true
DIRECT_URL=postgresql://postgres:password@db.xmmrwzzmoiemhkhvquth.supabase.co:5432/postgres

# JWT Secrets for Session Security
JWT_SECRET=dev_hyd_jwt_access_secret_key_2026
JWT_REFRESH_SECRET=dev_hyd_jwt_refresh_secret_key_2026
SESSION_SECRET=dev_hyd_session_secret_2026

# Admin Credentials (Auto-initialized on first run)
ADMIN_EMAIL=dev.hyd.official@gmail.com
ADMIN_PASSWORD=admin123!

# Email Notification Settings (Nodemailer / SMTP)
NOTIFY_EMAIL=dev.hyd.official@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dev.hyd.official@gmail.com
SMTP_PASS=your_app_password

# Supabase Platform Keys (Optional)
SUPABASE_URL=https://xmmrwzzmoiemhkhvquth.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Razorpay Integration (Optional)
RAZORPAY_KEY_ID=rzp_test_key
RAZORPAY_KEY_SECRET=rzp_test_secret
RAZORPAY_WEBHOOK_SECRET=rzp_test_webhook_secret

# Cloudinary Integration for Media Uploads (Optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
